        uuid id PK
        uuid user_id FK
        app_role role
    }
    VENUES {
        uuid id PK
        text name
        text city
        text area
        text venue_type
        int capacity
        numeric base_price
    }
    VENDOR_PROFILES {
        uuid id PK
        uuid user_id FK
        text business_name
        text city
    }
    VENDOR_LISTINGS {
        uuid id PK
        uuid vendor_profile_id FK
        uuid category_id FK
        text title
        text city
        numeric base_price
        boolean is_active
    }
    EVENT_CATEGORIES {
        uuid id PK
        text slug
        text name
    }
    CART_ITEMS {
        uuid id PK
        uuid user_id FK
        uuid venue_id FK
        uuid listing_id FK
        int quantity
    }
    BOOKINGS {
        uuid id PK
        uuid user_id FK
        numeric total_amount
        numeric amount_paid
        text status
        timestamptz created_at
    }
    BOOKING_ITEMS {
        uuid id PK
        uuid booking_id FK
        uuid venue_id FK
        uuid listing_id FK
        numeric unit_price
        int quantity
    }
    PAYMENT_PROOFS {
        uuid id PK
        uuid booking_id FK
