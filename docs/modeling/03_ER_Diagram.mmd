        boolean is_active
    }
    ALBUMS {
        uuid id PK
        text title
    }
    PHOTOS {
        uuid id PK
        uuid album_id FK
        text url
    }
    REVIEWS {
        uuid id PK
        uuid user_id FK
        int rating
        text body
    }
    ENQUIRIES {
        uuid id PK
        uuid user_id FK
        text message
    }
